# Database
POSTGRES_USER=vault
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vault
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://vault:changeme@db:5432/vault

# JWT Auth
JWT_SECRET=change-me-to-at-least-32-random-bytes-base64-encoded
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Single user seed
FIRST_USER_EMAIL=you@example.com
FIRST_USER_PASSWORD=changeme

# Embeddings (backend uses this key to embed approved summaries/facts only)
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
